maybe_print_first_welcome() {
  [ "${AEL_NO_ONBOARDING:-}" != "1" ] || return 0
  local marker="$PWD/.aiplus/.ael-greeted"
  if [ ! -e "$marker" ]; then
    printf 'Welcome to AEL — your research team is ready.\n\n'
    mkdir -p "$PWD/.aiplus"
    : > "$marker" 2>/dev/null || true
  fi
}

# Map free-form user input → canonical role slug. Returns empty string
# if no confident match. Designed to handle: English slugs ("pi",
# "ra-stata"), Chinese aliases ("顾问", "理论"), and short natural-
# language phrases ("我想反思 RD 设计" → advisor, "派给 RA 跑回归" →
# ra-stata).
detect_role_from_input() {
  local raw="$1"
  local lower
  lower="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"

  # Exact slug match (highest priority).
  case "$lower" in
    pi|advisor|writer|ra-stata|ra-python|theorist|referee|replicator|pm)
      printf '%s' "$lower"
      return 0
      ;;
  esac

  # Substring match across English + Chinese aliases. Order matters —
  # check more specific ones first (ra-stata before "ra").
  # shellcheck disable=SC2221,SC2222
  case "$lower" in
    *advisor*|*顾问*|*反思*|*识别*|*框架*|*战略*|*咨询*)
      printf 'advisor' ;;
    *ra-stata*|*ra_stata*|"ra stata"*|*ra-stata*|*stata*|*回归*|*实证*ra*|*跑表*|*跑回归*)
      printf 'ra-stata' ;;
    *ra-python*|*ra_python*|"ra python"*|*ra-python*|*python*ra*|*数据清洗*|*清洗*|*合并*数据*|*python*)
      printf 'ra-python' ;;
    *replicator*|*复现*|*复跑*|*clean.room*|*replication*)
      printf 'replicator' ;;
    *referee*|*内审*|*自审*|*审稿*)
      printf 'referee' ;;
    *theorist*|*理论*|*模型*|*识别假设*|*推导*)
      printf 'theorist' ;;
    *writer*|*写手*|*起草*|*写段落*|*draft*|*引言*|*introduction*|*写作*)
      printf 'writer' ;;
    *pm*|*项目经理*|*gantt*|*deadline*|*项目管理*|*acceptance*)
      # NOTE: only after "pi" exact-match fails — "pm" matches before "pi"
      # because pi above was an exact-only check.
      printf 'pm' ;;
    *pi*|*项目经理*|*派单*|*下达*|*执行*|*orchestrat*|*coordinator*)
      printf 'pi' ;;
    *)
      printf '' ;;
  esac
}

runtime_is_available_in_list() {
  local needle="$1"
  shift
  local runtime
  for runtime in "$@"; do
    if [ "$runtime" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

runtime_choice_from_input() {
  local input="$1"
  shift
  local lower index runtime
  lower="$(printf '%s' "$input" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"

  if [ -z "$lower" ]; then
    printf '%s' "$1"
    return 0
  fi

  if [ "$lower" = "claude" ]; then
    lower="claude-code"
  fi

  case "$lower" in
    codex|claude-code|opencode)
      if runtime_is_available_in_list "$lower" "$@"; then
        printf '%s' "$lower"
        return 0
      fi
      ;;
    ''|*[!0-9]*)
      ;;
    *)
      index=$((lower - 1))
      if [ "$index" -ge 0 ] && [ "$index" -lt "$#" ]; then
        local i=0
        for runtime in "$@"; do
          if [ "$i" -eq "$index" ]; then
            printf '%s' "$runtime"
            return 0
          fi
          i=$((i + 1))
        done
      fi
      ;;
  esac

  return 1
}

choose_lobby_runtime() {
  [ "$#" -gt 0 ] || die "no runtime installed for this project"

  AEL_SELECTED_RUNTIME=""
  if [ "$#" -eq 1 ]; then
    AEL_SELECTED_RUNTIME="$1"
    printf '→ %s (only installed runtime)\n\n' "$AEL_SELECTED_RUNTIME"
    return 0
  fi

  printf 'AEL — which runtime?\n'
  local i=1 runtime
  for runtime in "$@"; do
    printf '  %s) %s\n' "$i" "$runtime"
    i=$((i + 1))
  done
  printf '\n> '

  local runtime_input="" trimmed
  if ! IFS= read -r runtime_input; then
    exit 0
  fi
  trimmed="$(printf '%s' "$runtime_input" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  case "$trimmed" in
    q|quit|exit)
      exit 0
      ;;
  esac

  if ! AEL_SELECTED_RUNTIME="$(runtime_choice_from_input "$runtime_input" "$@")"; then
    printf '\nael: could not match "%s" to an installed runtime.\n' "$runtime_input" >&2
    exit 1
  fi
  printf '→ %s\n\n' "$AEL_SELECTED_RUNTIME"
}

chat_default() {
  # The natural-language entry point: a lobby that routes the user to
  # the team member they want. Replaces the previous "always drop into
  # PI" behavior so users can also reach Advisor / writer / RAs / etc.
  # directly.
  ensure_project_ready_for_lobby

  maybe_print_first_welcome
  printf 'AEL — 你想跟谁聊？ / who do you want to talk to?\n\n'
  list_team_members
  printf '\nType a name, slug, or describe what you need (中英文皆可).\n'
  printf '"q" / Ctrl-D to leave. Empty = PI.\n'
  printf '\n> '

  local user_input=""
  if ! IFS= read -r user_input; then
    exit 0
  fi

  local trimmed
  trimmed="$(printf '%s' "$user_input" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  case "$trimmed" in
    q|quit|exit|bye)
      exit 0
      ;;
  esac

  local role
  if [ -z "$trimmed" ]; then
    # Empty input → default to PI silently (matches the original lobby behavior).
    role='pi'
    printf '→ pi (default)\n\n'
  else
    role="$(detect_role_from_input "$user_input")"
    if [ -z "$role" ]; then
      printf '\nael: could not match "%s" to a team member. Defaulting to PI.\n\n' "$user_input" >&2
      role='pi'
    else
      printf '→ %s\n\n' "$role"
    fi
  fi

  choose_lobby_runtime "${AEL_LOBBY_RUNTIMES[@]}"

  # Re-exec ourselves so the TTY chain is clean (no nested shell layers).
  exec "$0" talk --runtime "$AEL_SELECTED_RUNTIME" "$role"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    "")
      chat_default
      ;;
    chat)
      shift
      chat_default
      ;;
    # Power-user shortcuts: `ael pi`, `ael advisor`, ... skip the lobby
    # and drop straight into that role's interactive chat. The lobby is
    # nicer for new users; these shortcuts are faster once you know who
    # you need.
    pi|advisor|writer|ra-stata|ra-python|theorist|referee|replicator|pm)
      shift
      shortcut_talk_cmd "$cmd" "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    -V|--version|version)
      printf 'AEL %s\n' "$AEL_VERSION"
      ;;
    install)
      shift
      install_cmd "$@"
      ;;
    talk)
      shift
      talk_cmd "$@"
      ;;
    status)
      shift
      run_substrate_visible agent status "$@"
      ;;
    doctor)
      shift
      doctor_cmd "$@"
      ;;
    update)
      shift
      update_cmd "$@"
      ;;
    uninstall)
      shift
      uninstall_cmd "$@"
      ;;
    route)
      shift
      run_substrate_visible agent route "$@"
      ;;
    telemetry)
      shift
      telemetry_cmd "$@"
      ;;
    invite|dismiss|integrate)
      local sub="$cmd"
      shift
      run_substrate_visible agent "$sub" "$@"
      ;;
    substrate)
      shift
      run_substrate_visible "$@"
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
